# --- Core Parameters ---
# Specify the full path to the output directory, e.g.: /home/user/scrapper/output
SCRAPER_OUTPUT_DIR=./output

# Telegram Bot configuration
# Use the format: https://api.telegram.org/bot<your_bot_token>/sendMessage
# The scraper will automatically replace <your_bot_token> with TELEGRAM_BOT_TOKEN
TELEGRAM_API_URL="https://api.telegram.org/bot<your_bot_token>/sendMessage"

# Bot token from @BotFather (e.g., 123456789:ABCdefGHIjklMNOpqrsTUV)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Your Chat ID from @userinfobot (e.g., 123456789)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# --- Search Parameters (User Parameters) ---
# Province (e.g.: Madrid, Barcelona, Alicante, Valencia)
PROVINCE=Valencia

# Office name exactly as it appears on the website (e.g.: "CNP VALENCIA-DOCUMENTACIÓN")
# Leave empty to search across all available offices in the province
OFFICE=

# Procedure name exactly as it appears on the website
PROCEDURE="POLICÍA TARJETA CONFLICTO UCRANIA–ПОЛІЦІЯ -КАРТКА ДЛЯ ПЕРЕМІЩЕНИХ ОСІБ ВНАСЛІДОК КОНФЛІКТУ В УКРАЇНІ"

# Your NIE (e.g.: Y1234567X)
NIE=Z1234567A

# Your full name (as in documents)
FULL_NAME=IVAN IVANOV

# Your country of birth/nationality (as in the website dropdown, e.g., UCRANIA, RUSIA)
COUNTRY=UCRANIA

# --- Contact Information ---
# Your phone number (e.g.: 612345678)
PHONE_NUMBER=600000000

# Your email address (e.g.: user@example.com)
EMAIL=your.email@gmail.com

# Unique session identifier for the Firefox profile
# Use this to separate sessions or maintain browser state
SCRAPER_SESSION_ID=mysession
